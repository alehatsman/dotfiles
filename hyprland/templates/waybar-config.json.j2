{
    "layer": "top",
    "position": "top",
    "height": 40,
    "spacing": 4,
    "modules-left": ["hyprland/workspaces"],
    "modules-center": [],
    "modules-right": ["custom/cpu-temp", "cpu", "memory", "backlight", "pulseaudio", "battery", "bluetooth", "network", "clock", "custom/power"],

    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate",
        "sort-by-number": true
    },

    "custom/cpu-temp": {
        "exec": "~/.local/bin/waybar-cpu-temp",
        "interval": 3,
        "return-type": "json"
    },

    "cpu": {
        "interval": 3,
        "format": " / {usage}%",
        "tooltip-format": "CPU util: {usage}%"
    },

    "memory": {
        "interval": 5,
        "format": "{used:0.1f}G",
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G ({percentage}%)"
    },

    "backlight": {
        "format": "َ°ƒں {percent}%",
        "tooltip-format": "Brightness: {percent}%",
        "on-scroll-up": "brightnessctl set +5%",
        "on-scroll-down": "brightnessctl set 5%-"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "َ°‌ں muted",
        "format-icons": {
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "tooltip-format": "Volume: {volume}% ({desc})",
        "on-click": "pavucontrol"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "َ°‚„ {capacity}%",
        "format-plugged": "َ°ڑ¥ {capacity}%",
        "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ¾", "َ°‚€", "َ°‚‚", "َ°پ¹"],
        "tooltip-format": "Battery: {capacity}% â€” {time}"
    },

    "bluetooth": {
        "format": "َ°‚¯",
        "format-disabled": "َ°‚²",
        "format-off": "َ°‚²",
        "format-connected": "َ°‚± {num_connections}",
        "tooltip-format": "BT: on\n{controller_alias}",
        "tooltip-format-disabled": "BT: disabled",
        "tooltip-format-off": "BT: off",
        "tooltip-format-connected": "BT: {num_connections} connected\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}",
        "on-click": "blueman-manager"
    },

    "network": {
        "format-wifi": "َ°¤¨",
        "format-ethernet": "َ°ˆ€",
        "format-disconnected": "َ°¤­",
        "tooltip-format-wifi": "Wi-Fi: {essid} ({signalStrength}%)\n{ifname}: {ipaddr}\nâ†“ {bandwidthDownBits}  â†‘ {bandwidthUpBits}",
        "tooltip-format-ethernet": "Ethernet: {ifname}\n{ipaddr}\nâ†“ {bandwidthDownBits}  â†‘ {bandwidthUpBits}",
        "tooltip-format-disconnected": "Net: disconnected",
        "on-click": "nm-connection-editor"
    },

    "clock": {
        "format": "{:%H:%M}",
        "tooltip-format": "<big>{:%A, %d %B %Y}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "custom/power": {
        "format": "âڈ»",
        "tooltip": false,
        "on-click": "wlogout"
    }
}
