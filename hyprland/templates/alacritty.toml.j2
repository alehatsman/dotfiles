[colors]
draw_bold_text_with_bright_colors = false

[colors.bright]
black   = "#75715E"
blue    = "#66D9EF"
cyan    = "#A1EFE4"
green   = "#A6E22E"
magenta = "#AE81FF"
red     = "#F92672"
white   = "#F9F8F5"
yellow  = "#F4BF75"

[colors.normal]
black   = "#272822"
blue    = "#66D9EF"
cyan    = "#A1EFE4"
green   = "#A6E22E"
magenta = "#AE81FF"
red     = "#F92672"
white   = "#F8F8F2"
yellow  = "#F4BF75"

[colors.primary]
background = "#272822"
foreground = "#F8F8F2"

[cursor]
style = "Block"
unfocused_hollow = true

[env]
TERM = "xterm-256color"

[font]
size = 12.0

[font.normal]
family = "JetBrainsMono NF"
style  = "Regular"

[font.bold]
family = "JetBrainsMono NF"
style  = "Bold"

[font.italic]
family = "JetBrainsMono NF"
style  = "Italic"

[mouse]
hide_when_typing = true

[scrolling]
history    = 10000
multiplier = 3

[selection]
save_to_clipboard      = false
semantic_escape_chars  = ",│`|:\"' ()[]{}<>"

[terminal.shell]
program = "/bin/zsh"
args    = ["--login"]

[window]
decorations    = "None"
dynamic_padding = false
opacity        = 1.0

[window.dimensions]
columns = 100
lines   = 35

[window.padding]
x = 8
y = 8

# Alt key bindings for zsh word navigation
[[keyboard.bindings]]
chars = "\u001bb"
key   = "B"
mods  = "Alt"

[[keyboard.bindings]]
chars = "\u001bf"
key   = "F"
mods  = "Alt"

[[keyboard.bindings]]
chars = "\u001bd"
key   = "D"
mods  = "Alt"

[[keyboard.bindings]]
chars = "\u001b."
key   = "Period"
mods  = "Alt"

# Ctrl+C / Ctrl+V copy & paste. Cost: Ctrl+C no longer sends SIGINT —
# use Super+C (below) to interrupt the foreground process instead.
[[keyboard.bindings]]
action = "Copy"
key    = "C"
mods   = "Control"

[[keyboard.bindings]]
action = "Paste"
key    = "V"
mods   = "Control"

# Super+C sends ETX (0x03), the byte Ctrl+C normally sends. The kernel
# turns it into SIGINT for the foreground process.
[[keyboard.bindings]]
chars = "\u0003"
key   = "C"
mods  = "Super"
