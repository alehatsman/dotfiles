/* Make the GTK root window fully transparent so the rectangular layer
   surface can't leak any background/shadow at the corners. The visible
   panel (background + border + rounded corners) lives on #outer-box. */
window,
window:backdrop {
    margin: 0;
    border: none;
    background-color: transparent;
    font-family: "JetBrainsMono Nerd Font", monospace;
    font-size: 14px;
    box-shadow: none;
}

#outer-box {
    margin: 0;
    border: 1px solid #3e3d32;
    border-radius: 8px;
    background-color: #272822;
    padding: 4px;
}

#input {
    margin: 8px;
    border: 1px solid #3e3d32;
    border-radius: 4px;
    background-color: #3e3d32;
    color: #f8f8f2;
    caret-color: #f8f8f2;
    -gtk-secondary-caret-color: #66d9ef;
    padding: 8px 12px;
    outline: none;
}

#input:focus {
    border-color: #66d9ef;
}

#inner-box,
#scroll {
    margin: 4px;
    background-color: transparent;
}

#text {
    margin: 2px 8px;
    color: #75715e;
}

#entry {
    border-radius: 4px;
    padding: 2px;
    background-color: transparent;
}

#entry box,
#entry expander,
#entry list,
#entry row {
    background-color: #272822;
    color: #f8f8f2;
}

#entry row:selected,
#entry row:hover {
    background-color: #3e3d32;
    color: #f8f8f2;
}

#entry:selected {
    background-color: #3e3d32;
}

#entry:selected #text {
    color: #f8f8f2;
}
