* {
    border: none;
    border-radius: 0;
    font-family: "JetBrainsMono Nerd Font", monospace;
    font-size: 15px;
    min-height: 0;
}

window#waybar {
    background-color: rgba(39, 40, 34, 0.95);
    color: #f8f8f2;
    border-bottom: 1px solid #3e3d32;
}

tooltip {
    background: #272822;
    border: 1px solid #3e3d32;
    border-radius: 4px;
}

tooltip label {
    color: #f8f8f2;
    padding: 6px 10px;
}

#workspaces {
    padding: 0 4px;
}

#workspaces button {
    padding: 0 10px;
    background: transparent;
    color: #75715e;
    border-bottom: 2px solid transparent;
    box-shadow: none;
    transition: all 0.15s ease;
}

#workspaces button.active {
    color: #f8f8f2;
    background: #3e3d32;
    border-bottom: 2px solid #66d9ef;
    box-shadow: none;
}

#workspaces button.urgent {
    color: #f92672;
    border-bottom: 2px solid #f92672;
    box-shadow: none;
}

#workspaces button:hover {
    color: #f8f8f2;
    background: rgba(62, 61, 50, 0.6);
    background-image: none;
    box-shadow: none;
    text-shadow: none;
}

#window {
    color: #75715e;
    padding: 0 8px;
}

#clock {
    color: #f8f8f2;
    padding: 0 8px;
}

#custom-cpu-temp,
#cpu,
#memory,
#backlight,
#pulseaudio,
#battery,
#bluetooth,
#network,
#custom-power {
    color: #f8f8f2;
    padding: 0 8px;
}

/* Pair cpu-temp + cpu-util visually so "47°C / 25%" reads as one block */
#custom-cpu-temp {
    padding-right: 0;
}
#cpu {
    padding-left: 0;
}

#custom-cpu-temp.critical {
    color: #f92672;
}

#temperature.critical {
    color: #f92672;
}

#custom-power {
    padding-right: 14px;
    margin-right: 4px;
}

#battery.charging,
#battery.plugged {
    color: #a6e22e;
}

#battery.warning {
    color: #fd971f;
}

#battery.critical {
    color: #f92672;
    animation: blink 0.5s infinite alternate;
}

#network,
#bluetooth {
    color: #75715e;
}

#network.wifi,
#network.ethernet,
#network.linked,
#bluetooth.connected {
    color: #a6e22e;
}

#pulseaudio.muted {
    color: #75715e;
}

#tray {
    padding: 0 8px;
}

@keyframes blink {
    to {
        color: #272822;
        background-color: #f92672;
    }
}
