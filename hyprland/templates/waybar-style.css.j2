* {
    border: none;
    border-radius: 0;
    font-family: "JetBrainsMono Nerd Font", monospace;
    font-size: 15px;
    min-height: 0;
}

window#waybar {
    background-color: rgba(39, 40, 34, 0.95);
    color: #f8f8f2;
    border-bottom: 1px solid #3e3d32;
}

#workspaces {
    padding: 0 4px;
}

#workspaces button {
    padding: 0 10px;
    background-color: transparent;
    color: #75715e;
    border-bottom: 2px solid transparent;
    transition: all 0.15s ease;
}

#workspaces button.active {
    color: #f8f8f2;
    background-color: #3e3d32;
    border-bottom: 2px solid #66d9ef;
}

#workspaces button.urgent {
    color: #f92672;
    border-bottom: 2px solid #f92672;
}

#workspaces button:hover {
    color: #f8f8f2;
    background-color: rgba(62, 61, 50, 0.6);
}

#window {
    color: #75715e;
    padding: 0 8px;
}

#clock {
    color: #f8f8f2;
    padding: 0 8px;
}

#temperature,
#backlight,
#pulseaudio,
#battery,
#bluetooth,
#network,
#custom-power {
    color: #f8f8f2;
    padding: 0 8px;
}

#temperature.critical {
    color: #f92672;
}

#custom-power {
    padding-right: 14px;
    margin-right: 4px;
}

#battery.charging,
#battery.plugged {
    color: #a6e22e;
}

#battery.warning {
    color: #fd971f;
}

#battery.critical {
    color: #f92672;
    animation: blink 0.5s infinite alternate;
}

#network.disconnected,
#pulseaudio.muted,
#bluetooth.disabled,
#bluetooth.off {
    color: #75715e;
}

#tray {
    padding: 0 8px;
}

@keyframes blink {
    to {
        color: #272822;
        background-color: #f92672;
    }
}
