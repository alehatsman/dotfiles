[global]
    monitor = 0
    follow = mouse
    width = 320
    height = (0, 300)
    origin = top-right
    offset = (12, 48)
    padding = 12
    horizontal_padding = 12
    frame_width = 1
    frame_color = "#a6e22e"
    separator_color = frame
    font = JetBrainsMono Nerd Font 11
    line_height = 2
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    icon_theme = Adwaita, hicolor
    enable_recursive_icon_lookup = true
    corner_radius = 6
    history_length = 20
    show_indicators = false

[urgency_low]
    background = "#272822"
    foreground = "#f8f8f2"
    timeout = 4

[urgency_normal]
    background = "#272822"
    foreground = "#f8f8f2"
    timeout = 6

[urgency_critical]
    background = "#272822"
    foreground = "#f92672"
    frame_color = "#f92672"
    timeout = 0
