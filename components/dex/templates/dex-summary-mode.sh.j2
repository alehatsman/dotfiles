#!/usr/bin/env bash
# dex-summary-mode {steady|burst|flood|status} — flip the dex summary router mode.
#
#   burst   The chunk tier (3b) is lent to this box's local GPU (the 5090)
#           while the heavier tiers stay on the remote worker (5080). The 32b
#           ask model stays pinned — interactive `ask` is unaffected. One card
#           helps at a time (the drainer runs file then chunk phases).
#   flood   BOTH GPUs run the full tier mix at once: the 32b ask model is
#           evicted to free the 5090, and the router round-robins every summary
#           across both cards. Drainer concurrency and batch size are bumped via
#           a systemd drop-in so both cards stay saturated. Maximum summary
#           throughput; interactive `ask` on the 5090 PAUSES until steady.
#   steady  All summaries go back to the remote worker (the default). Re-warms
#           the evicted ask model and stops the summary-only tiers left resident
#           on the 5090 (this box's ollama runs OLLAMA_KEEP_ALIVE=-1, so lent
#           models stay pinned until explicitly stopped — keeping 7b alone since
#           it's the compress model).
#   status  print the current mode.
#
# Deployed by components/dex/index.yml — do not edit by hand. dotfiles #32, #34.
set -euo pipefail

MODE_FILE="${DEX_ROUTER_MODE_FILE:-$HOME/.config/dex/summary-router.mode}"
EMBED_URL="${DEX_EMBED_URL:-http://127.0.0.1:{{ dex_local_port }}}"
LOCAL_MODELS="{{ dex_summary_router_local_models }}"
FLOOD_EVICT="{{ dex_summary_router_flood_evict }}"   # freed on flood, re-warmed on steady
STEADY_STOP="{{ dex_summary_router_steady_stop }}"   # summary-only tiers freed on steady
FLOOD_CONCURRENCY="{{ dex_summary_flood_concurrency }}"
FLOOD_BATCH="{{ dex_summary_flood_batch }}"
DROPIN_FILE="${HOME}/.config/systemd/user/dex-serve.service.d/flood-override.conf"

_stop() {  # space/comma-separated model list -> ollama stop each
  command -v ollama >/dev/null 2>&1 || return 0
  local _m
  for _m in ${1//,/ }; do ollama stop "$_m" >/dev/null 2>&1 || true; done
}

_warm() {  # load + pin (keep_alive -1) each model so foreground ask is hot
  local _m
  for _m in ${1//,/ }; do
    curl -s --max-time 120 "${EMBED_URL}/api/generate" \
      -d "{\"model\":\"${_m}\",\"prompt\":\"\",\"stream\":false,\"keep_alive\":-1}" \
      >/dev/null 2>&1 || true
  done
}

_apply_flood_drainer() {
  mkdir -p "$(dirname "$DROPIN_FILE")"
  printf '[Service]\nEnvironment=DEX_SUMMARY_CONCURRENCY=%s\nEnvironment=DEX_SUMMARIZE_BATCH=%s\n' \
    "$FLOOD_CONCURRENCY" "$FLOOD_BATCH" > "$DROPIN_FILE"
  systemctl --user daemon-reload
  systemctl --user restart dex-serve.service
}

_clear_flood_drainer() {
  rm -f "$DROPIN_FILE"
  systemctl --user daemon-reload
  systemctl --user restart dex-serve.service
}

case "${1:-status}" in
  burst)
    mkdir -p "$(dirname "$MODE_FILE")"; echo burst > "$MODE_FILE"
    echo "summary router → burst (chunk tier → local GPU: ${LOCAL_MODELS})"
    ;;
  flood)
    mkdir -p "$(dirname "$MODE_FILE")"
    docker stop dex-rerank 2>/dev/null || true   # free ~24 GB VRAM (vLLM float16 pre-alloc) before ollama loads
    _stop "$FLOOD_EVICT"          # free the 5090 before loading the summary tier
    _warm "$LOCAL_MODELS"         # pre-load summary model so first batch doesn't cold-start under timeout
    _apply_flood_drainer          # bump concurrency + batch; restarts dex-serve
    echo flood > "$MODE_FILE"
    echo "summary router → flood (BOTH GPUs; evicted: ${FLOOD_EVICT}; reranker stopped; concurrency=${FLOOD_CONCURRENCY} batch=${FLOOD_BATCH}; ask paused until steady)"
    ;;
  steady)
    mkdir -p "$(dirname "$MODE_FILE")"; echo steady > "$MODE_FILE"
    _clear_flood_drainer          # restore default concurrency + batch; restarts dex-serve
    _stop "$LOCAL_MODELS $STEADY_STOP"   # drop summary-only tiers left on the 5090
    _warm "$FLOOD_EVICT"                  # re-pin the ask model
    docker start dex-rerank 2>/dev/null || true  # restore reranker now that flood VRAM is freed
    echo "summary router → steady (all → remote; re-warmed: ${FLOOD_EVICT}; reranker restored)"
    ;;
  status|"")
    echo "mode: $(cat "$MODE_FILE" 2>/dev/null || echo steady)  (file: $MODE_FILE)"
    ;;
  *)
    echo "usage: dex-summary-mode {steady|burst|flood|status}" >&2
    exit 2
    ;;
esac
