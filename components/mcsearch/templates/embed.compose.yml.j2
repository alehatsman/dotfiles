# mcsearch embedding service.
#
# {% if mcsearch_engine == 'vllm' %}Engine: vLLM (OpenAI-compatible /v1/embeddings){% else %}Engine: text-embeddings-inference (TEI){% endif %}.
# Binds 127.0.0.1:{{ mcsearch_remote_port }} only — clients reach it via
# SSH tunnel, never directly over the LAN. See
# components/mcsearch/templates/mcsearch-tunnel.service.j2.

services:
  mcsearch-embed:
    container_name: mcsearch-embed
{% if mcsearch_engine == 'vllm' %}
    image: {{ mcsearch_vllm_image }}
    # Embedding-only task on the indexing model. vLLM auto-detects the
    # embedding head when --task embed is passed.
    command:
      - --model
      - {{ mcsearch_embed_model }}
      - --task
      - embed
      - --port
      - "{{ mcsearch_remote_port }}"
      - --host
      - "0.0.0.0"           # inside the container; only the host-side
                            # 127.0.0.1 binding below leaks to the world
      - --max-model-len
      - "{{ mcsearch_max_model_len }}"
      - --gpu-memory-utilization
      - "0.45"              # leaves ~55% VRAM headroom for an eventual
                            # local-coder model on the same GPU (M5)
    ipc: host
{% else %}
    image: {{ mcsearch_tei_image }}
    command:
      - --model-id
      - {{ mcsearch_embed_model }}
      - --port
      - "{{ mcsearch_remote_port }}"
{% endif %}
    restart: unless-stopped
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
    # 127.0.0.1 binding — anything off-host must go through ssh -L
    ports:
      - "127.0.0.1:{{ mcsearch_remote_port }}:{{ mcsearch_remote_port }}"
    volumes:
      # Cache HF model files outside the container so re-pulls are fast.
      - /opt/mcsearch/hf-cache:/root/.cache/huggingface
    environment:
      - HUGGING_FACE_HUB_TOKEN=${HUGGING_FACE_HUB_TOKEN:-}
    healthcheck:
      test:
        - CMD-SHELL
        - "curl -sf -X POST -H 'Content-Type: application/json' -d '{\"model\":\"{{ mcsearch_embed_model }}\",\"input\":[\"ping\"]}' http://127.0.0.1:{{ mcsearch_remote_port }}/v1/embeddings || exit 1"
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 120s
