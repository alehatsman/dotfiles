window {
    background: rgba(39, 40, 34, 0.85);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.06);
}

#box {
    padding: 6px 10px;
}

#active {
    border-bottom: 2px solid #66d9ef;
}

button, image {
    background: none;
    border-style: none;
    box-shadow: none;
}

button {
    padding: 4px;
    margin: 0 3px;
    border-radius: 10px;
}

button:hover {
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: 10px;
}

button:focus {
    box-shadow: none;
}
