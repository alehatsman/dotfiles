window {
    background: rgba({{ palette.bg_rgb }}, 0.85);
    border-radius: 16px;
    border: 1px solid rgba({{ palette.overlay_rgb }}, 0.06);
}

#box {
    padding: 6px 10px;
}

#active {
    border-bottom: 2px solid {{ palette.cyan }};
}

button, image {
    background: none;
    border-style: none;
    box-shadow: none;
}

button {
    padding: 4px;
    margin: 0 3px;
    border-radius: 10px;
}

button:hover {
    background-color: rgba({{ palette.overlay_rgb }}, 0.1);
    border-radius: 10px;
}

button:focus {
    box-shadow: none;
}
