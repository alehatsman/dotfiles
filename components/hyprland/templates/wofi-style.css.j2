/* Make the GTK root window fully transparent so the rectangular layer
   surface can't leak any background/shadow at the corners. The visible
   panel (background + border + rounded corners) lives on #outer-box. */
window,
window:backdrop {
    margin: 0;
    border: none;
    background-color: transparent;
    font-family: "JetBrainsMono Nerd Font", monospace;
    font-size: 14px;
    box-shadow: none;
}

#outer-box {
    margin: 0;
    border: 1px solid {{ palette.panel }};
    border-radius: 8px;
    background-color: {{ palette.bg }};
    padding: 4px;
}

#input {
    margin: 8px;
    border: 1px solid {{ palette.panel }};
    border-radius: 4px;
    background-color: {{ palette.panel }};
    color: {{ palette.fg }};
    caret-color: {{ palette.fg }};
    -gtk-secondary-caret-color: {{ palette.cyan }};
    padding: 8px 12px;
    outline: none;
}

#input:focus {
    border-color: {{ palette.cyan }};
}

#inner-box,
#scroll {
    margin: 4px;
    background-color: transparent;
}

#text {
    margin: 2px 8px;
    color: {{ palette.muted }};
}

#entry {
    border-radius: 4px;
    padding: 2px;
    background-color: transparent;
}

#entry box,
#entry expander,
#entry list,
#entry row {
    background-color: {{ palette.bg }};
    color: {{ palette.fg }};
}

#entry row:selected,
#entry row:hover {
    background-color: {{ palette.panel }};
    color: {{ palette.fg }};
}

#entry:selected {
    background-color: {{ palette.panel }};
}

#entry:selected #text {
    color: {{ palette.fg }};
}
