* {
    border: none;
    border-radius: 0;
    font-family: "JetBrainsMono Nerd Font", monospace;
    font-size: 15px;
    min-height: 0;
}

window#waybar {
    background-color: rgba({{ palette.bg_rgb }}, 0.95);
    color: {{ palette.fg }};
    border-bottom: 1px solid {{ palette.panel }};
}

tooltip {
    background: {{ palette.bg }};
    border: 1px solid {{ palette.panel }};
    border-radius: 4px;
}

tooltip label {
    color: {{ palette.fg }};
    padding: 6px 10px;
}

#workspaces {
    padding: 0 4px;
}

#workspaces button {
    padding: 0 10px;
    background: transparent;
    color: {{ palette.muted }};
    border-bottom: 2px solid transparent;
    box-shadow: none;
    transition: all 0.15s ease;
}

#workspaces button.active {
    color: {{ palette.fg }};
    background: {{ palette.panel }};
    border-bottom: 2px solid {{ palette.cyan }};
    box-shadow: none;
}

#workspaces button.urgent {
    color: {{ palette.red }};
    border-bottom: 2px solid {{ palette.red }};
    box-shadow: none;
}

#workspaces button:hover {
    color: {{ palette.fg }};
    background: rgba({{ palette.panel_rgb }}, 0.6);
    background-image: none;
    box-shadow: none;
    text-shadow: none;
}

#window {
    color: {{ palette.muted }};
    padding: 0 8px;
}

#clock {
    color: {{ palette.fg }};
    padding: 0 8px;
}

#custom-cpu-temp,
#cpu,
#custom-cpu-power,
#memory,
#backlight,
#pulseaudio,
#battery,
#bluetooth,
#network,
#custom-power {
    color: {{ palette.fg }};
    padding: 0 8px;
}

/* Group cpu-temp + cpu-util + cpu-power so "47°C / 25% / 3W" reads as one block */
#custom-cpu-temp {
    padding-right: 0;
}
#cpu {
    padding-left: 0;
    padding-right: 0;
}
#custom-cpu-power {
    padding-left: 0;
}

#custom-cpu-temp.critical,
#custom-cpu-power.critical {
    color: {{ palette.red }};
}

#temperature.critical {
    color: {{ palette.red }};
}

#custom-power {
    padding-right: 14px;
    margin-right: 4px;
}

#battery.charging,
#battery.plugged {
    color: {{ palette.green }};
}

#battery.warning {
    color: {{ palette.orange }};
}

#battery.critical {
    color: {{ palette.red }};
    animation: blink 0.5s infinite alternate;
}

#network {
    color: {{ palette.muted }};
}

#network.wifi,
#network.ethernet,
#network.linked,
#bluetooth.connected {
    color: {{ palette.green }};
}

#bluetooth.disabled,
#bluetooth.off {
    color: {{ palette.muted }};
}

#pulseaudio.muted {
    color: {{ palette.muted }};
}

#tray {
    padding: 0 8px;
}

@keyframes blink {
    to {
        color: {{ palette.bg }};
        background-color: {{ palette.red }};
    }
}
