[colors]
draw_bold_text_with_bright_colors = false

[colors.bright]
black   = "{{ palette.muted }}"
blue    = "{{ palette.cyan }}"
cyan    = "{{ palette.bright_cyan }}"
green   = "{{ palette.green }}"
magenta = "{{ palette.magenta }}"
red     = "{{ palette.red }}"
white   = "{{ palette.fg }}"
yellow  = "{{ palette.yellow }}"

[colors.normal]
black   = "{{ palette.bg }}"
blue    = "{{ palette.cyan }}"
cyan    = "{{ palette.bright_cyan }}"
green   = "{{ palette.green }}"
magenta = "{{ palette.magenta }}"
red     = "{{ palette.red }}"
white   = "{{ palette.fg }}"
yellow  = "{{ palette.yellow }}"

[colors.primary]
background = "{{ palette.bg }}"
foreground = "{{ palette.fg }}"

[cursor]
style = "Block"
unfocused_hollow = true

[env]
TERM = "xterm-256color"

[font]
size = 12.0

[font.normal]
family = "JetBrainsMono NF"
style  = "Regular"

[font.bold]
family = "JetBrainsMono NF"
style  = "Bold"

[font.italic]
family = "JetBrainsMono NF"
style  = "Italic"

[mouse]
hide_when_typing = true

[scrolling]
history    = 10000
multiplier = 3

[selection]
save_to_clipboard      = false
semantic_escape_chars  = ",│`|:\"' ()[]{}<>"

[terminal.shell]
program = "/bin/zsh"
args    = ["--login"]

[window]
decorations    = "None"
dynamic_padding = false
opacity        = 1.0

[window.dimensions]
columns = 100
lines   = 35

[window.padding]
x = 8
y = 8

# Alt key bindings for zsh word navigation
[[keyboard.bindings]]
chars = "\u001bb"
key   = "B"
mods  = "Alt"

[[keyboard.bindings]]
chars = "\u001bf"
key   = "F"
mods  = "Alt"

[[keyboard.bindings]]
chars = "\u001bd"
key   = "D"
mods  = "Alt"

[[keyboard.bindings]]
chars = "\u001b."
key   = "Period"
mods  = "Alt"

# Copy/paste lives on Super+C / Super+V system-wide (Hyprland → wm-clip),
# which sends Ctrl+Shift+C/V here. Defaults handle the rest:
# Ctrl+C → SIGINT, Ctrl+Shift+C/V → Copy/Paste.
