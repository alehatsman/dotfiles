[global]
    monitor = 0
    follow = mouse
    width = 320
    height = (0, 300)
    origin = top-right
    offset = (12, 48)
    padding = 12
    horizontal_padding = 12
    frame_width = 1
    # Neutral frame — Sublime ST2 reserves the green accent for actual
    # success state. urgency_critical overrides this with red below.
    frame_color = "{{ palette.panel }}"
    separator_color = frame
    font = JetBrainsMono Nerd Font 11
    line_height = 2
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    icon_theme = Adwaita, hicolor
    enable_recursive_icon_lookup = true
    corner_radius = 6
    history_length = 20
    show_indicators = false

[urgency_low]
    background = "{{ palette.bg }}"
    foreground = "{{ palette.fg }}"
    timeout = 4

[urgency_normal]
    background = "{{ palette.bg }}"
    foreground = "{{ palette.fg }}"
    timeout = 6

[urgency_critical]
    background = "{{ palette.bg }}"
    foreground = "{{ palette.red }}"
    frame_color = "{{ palette.red }}"
    timeout = 0
