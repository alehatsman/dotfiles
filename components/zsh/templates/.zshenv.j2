# ~/.zshenv — sourced by EVERY zsh (interactive, non-interactive, scripts,
# cron). Environment that must be present regardless of shell type lives here;
# interactive-only setup (prompt, plugins, aliases) stays in ~/.zshrc.
# Template-managed by components/zsh — single source of truth is
# shared/variables.yml. Do not hand-edit.

# Rust/cargo — guarded so a box without rustup doesn't error on every shell.
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# dex — point ad-hoc CLI invocations at the same endpoint + model that the MCP
# registration (components/dex/index.yml) and the watch/serve units use. Lives
# in .zshenv (not .zshrc) so NON-interactive shells — scripts, cron, agent
# tool-shells, `zsh -c` — get them too; otherwise a bare `dex` there falls back
# to the binary's compiled defaults (8082 + Qwen/Qwen3-Embedding-4B, 2560-dim),
# which mismatch the nomic-built index (768-dim) and fail with a dim error
# (dotfiles #33).
export DEX_EMBED_URL=http://127.0.0.1:{{ props.dex_local_port }}
export DEX_EMBED_MODEL={{ props.dex_embed_model }}
export DEX_CHAT_URL=http://127.0.0.1:{{ props.dex_local_port }}
export DEX_CHAT_MODEL={{ props.dex_chat_model }}
export DEX_ASK_MODEL={{ props.dex_ask_model }}
export DEX_COMPRESS_URL=http://127.0.0.1:{{ props.dex_compress_port }}
export DEX_COMPRESS_MODEL={{ props.dex_compress_model }}
{% if props.dex_draft_port %}
export DEX_DRAFT_URL=http://127.0.0.1:{{ props.dex_draft_port }}
export DEX_DRAFT_MODEL={{ props.dex_draft_model }}
{% endif %}
{% if props.dex_rerank_local_port %}
export DEX_RERANK_URL=http://127.0.0.1:{{ props.dex_rerank_local_port }}
export DEX_RERANK_STYLE={{ props.dex_rerank_style }}
export DEX_RERANK_MODEL={{ props.dex_rerank_model }}
export DEX_RERANK_POOL={{ props.dex_rerank_pool }}
export DEX_RERANK_CONCURRENCY={{ props.dex_rerank_concurrency }}
{% endif %}
