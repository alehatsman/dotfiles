#---------------------------------------------
# Color scheme (robust, shellcheck-safe)
#---------------------------------------------
setopt PROMPT_SUBST

: "${COLOR_SCHEME:=molokai}"
: "${RUNO_ARROW_ICON:=➜ }"

# Minimal git branch on the right, if vcs_info is available
autoload -Uz vcs_info 2>/dev/null && precmd() { vcs_info }
zstyle ':vcs_info:git:*' formats '%F{yellow} %b%f'
RPROMPT='${vcs_info_msg_0_}'

apply_theme() {
  local scheme="${1}"
  case "${scheme}" in
    molokai)
      # Prompt: green when last cmd OK, red when failed; path; reset
      PROMPT='%(?.%F{green}.%F{red})'"${RUNO_ARROW_ICON}"'%F{red}%B%~%b%f '
      # fzf — colors come from the palette mooncake component
      # (components/palette/vars/{{ palette_variant }}.yml). The
      # previous literal block had three typos vs canonical Monokai:
      #   green  #A6E22D → #A6E22E   border #3f4145 → palette.panel
      #   bg+    #2D2E27 → palette.panel (one shared "selected" tone
      #                                    instead of an off-palette grey)
      export FZF_DEFAULT_OPTS=$'--reverse \
        --color=fg:{{ palette.fg }},bg:{{ palette.bg }},hl:{{ palette.cyan }} \
        --color=fg+:{{ palette.fg }},bg+:{{ palette.panel }},hl+:{{ palette.cyan }} \
        --color=info:{{ palette.green }},prompt:{{ palette.red }},spinner:{{ palette.magenta }},pointer:{{ palette.magenta }},marker:{{ palette.green }},border:{{ palette.panel }},header:{{ palette.muted }}'
      export FZF_PREVIEW_COMMAND='bat --theme Monokai\ Extended\ Origin --style=plain --color=always {}'
      export BAT_THEME='Monokai Extended Origin'
      ;;
    runo)
      PROMPT='%(?.%F{green}.%F{red})'"${RUNO_ARROW_ICON}"'%F{blue}%B%~%b%f '
      export FZF_DEFAULT_OPTS=$'--reverse \
        --color=fg:#313232,bg:#f8f9f9,hl:#FFBC5D \
        --color=fg+:#313232,bg+:#eeefef,hl+:#FFBC5D \
        --color=info:#313232,border:#313232,prompt:#313232,pointer:#313232,marker:#313232,spinner:#313232,header:#FFFABC'
      unset FZF_PREVIEW_COMMAND
      unset BAT_THEME
      ;;
    github-light)
      PROMPT='%(?.%F{green}.%F{red})'"${RUNO_ARROW_ICON}"'%F{red}%B%~%b%f '
      export FZF_DEFAULT_OPTS=$'--reverse \
        --color=fg:#24292f,bg:#ffffff,hl:#0366d6 \
        --color=fg+:#24292f,bg+:#f6f8fa,hl+:#0366d6 \
        --color=info:#24292f,border:#d0d7de,prompt:#d73a49,pointer:#24292f,marker:#28a745,spinner:#5a32a3,header:#24292f'
      export FZF_PREVIEW_COMMAND='bat --theme GitHub --style=plain --color=always {}'
      export BAT_THEME='GitHub'
      ;;
    *)
      PROMPT='%(?.%F{green}.%F{red})'"${RUNO_ARROW_ICON}"'%F{cyan}%B%~%b%f '
      unset FZF_PREVIEW_COMMAND
      unset BAT_THEME
      ;;
  esac
}

