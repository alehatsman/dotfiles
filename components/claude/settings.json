{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "editorMode": "vim",
  "env": {
    "GOWORK": "off"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "skipDangerousModePermissionPrompt": true,
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(git commit*)",
      "Bash(git push*)"
    ]
  },
  "enabledPlugins": {
    "lua-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v mcsearch >/dev/null 2>&1 && [ -n \"$CLAUDE_PROJECT_DIR\" ] && mcsearch index \"$CLAUDE_PROJECT_DIR\" >/dev/null 2>&1",
            "async": true
          }
        ]
      }
    ]
  }
}
