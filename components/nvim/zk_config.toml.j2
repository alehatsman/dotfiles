{% verbatim %}# Managed by mooncake (components/nvim/index.yml). Do not edit by hand —
# change components/nvim/zk_config.toml.j2 and re-apply the `zk` tag.
#
# The whole file is wrapped in a {% verbatim %} block so zk's own
# {{ }} handlebars pass through unevaluated by the mooncake templater.

[note]
language = "en"
default-title = "Untitled"
# Short stable IDs as filenames; the human title lives in the front-matter.
filename = "{{id}}"
extension = "md"
template = "default.md"
id-charset = "alphanum"
id-length = 4
id-case = "lower"

[format.markdown]
# [[wiki links]] for fast linking; hashtags for tagging.
link-format = "wiki"
hashtags = true
colon-tags = true

# Daily journal: `:ZkNew { dir = 'journal/daily' }` lands here and the
# filename becomes the date instead of a random id.
[group.daily]
paths = ["journal/daily"]
[group.daily.note]
filename = "{{format-date now '%Y-%m-%d'}}"

[tool]
editor = "nvim"
pager = "less -FIRX"
fzf-preview = "bat -p --color always {-1}"
{% endverbatim %}
