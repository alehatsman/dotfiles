#---------------------------------------------
# Plugins
#---------------------------------------------

# tmp - plugin manager
# Prefix + I - install plugins
# Prefix + U - update plugins
set -g @plugin 'tmux-plugins/tpm'

# predefined settings
set -g @plugin 'tmux-plugins/tmux-sensible'

# regex search
set -g @plugin 'tmux-plugins/tmux-copycat'

# open highlighted selection
set -g @plugin 'tmux-plugins/tmux-open'

# persistent tmux sessons
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'

set -g @continuum-restore 'on'

{% if os == "darwin" %}
# set-environment -g PATH "/opt/local/bin:/bin:/usr/bin"
set-option -g default-shell /opt/homebrew/bin/zsh
{% endif %}

# Run tmp
run '~/.config/tmux/plugins/tpm/tpm'

#---------------------------------------------
# Configuration
#---------------------------------------------
{% if os == 'Archlinux' %}
set-option -g default-shell $SHELL
{% endif %}

set -g default-terminal "screen-256color" # colors!
# tell Tmux that outside terminal supports true color
set -ga terminal-overrides ",xterm-256color*:Tc"
# tell Tmux the outer terminal accepts OSC 52 so set-clipboard actually
# emits the escape — makes remote-tmux copy land in the local clipboard
# over SSH (e.g. WSL tmux on main_pc → alacritty on x1 → wl-clipboard).
set -ga terminal-features ",xterm-256color*:clipboard"

# 'on' (vs the tmux default 'external') also passes OSC 52 emitted by
# apps inside the pane (vim+oscyank, printf '\e]52;...', etc.) out to
# the outer terminal — not just tmux's own copy-mode operations.
set -g set-clipboard on

# decrease command delay (increases vim responsiveness)
set-option -sg escape-time 0

# use vim key bindings
setw -g mode-keys vi

# disable mouse
set -g mouse off

# start windows at 1, not 0
set -g base-index 1

# start panes at 1, not 0
setw -g pane-base-index 1

# re-number windows when one is closed
set -g renumber-windows on

#---------------------------------------------
# Status bar styles (tabs)
#---------------------------------------------
setw -g status-left ""
setw -g status-right ""

setw -g window-status-format " #I: #W "
setw -g window-status-current-format " #I: #W "

#---------------------------------------------
# Bindings
#---------------------------------------------

# Remap prefix from 'C-b' to 'C-t'
unbind C-b
set-option -g prefix C-t
bind-key C-t send-prefix

# reload config
bind r source-file ~/.tmux.conf \; display-message "~/.tmux.conf reloaded"

# split window vertically
bind v split-window -h -c "#{pane_current_path}"
bind s split-window -v -c "#{pane_current_path}"

unbind '"'
unbind %

bind w choose-session -Z -O name

#---------------------------------------------
# Panes
#---------------------------------------------

# move window left and right in the window list
bind-key -n S-Left swap-window -t -1\; select-window -t -1
bind-key -n S-Right swap-window -t +1\; select-window -t +1

# move current pane within the window (mirror of the above, but for panes)
bind -r S-Left  swap-pane -t '{left}'
bind -r S-Down  swap-pane -t '{down}'
bind -r S-Up    swap-pane -t '{up}'
bind -r S-Right swap-pane -t '{right}'

# create new pane
bind c new-window -c '#{pane_current_path}'

# move panes across sessions: mark a pane with `m`, then in the destination
# pane use `V`/`S` to pull the marked pane in as a split (mirror of v/s).
# `B` is the inverse: send current pane to its own window.
bind m select-pane -m \; display-message "#{?pane_marked,pane marked,pane unmarked}"
bind V join-pane -h
bind S join-pane
bind B break-pane

#---------------------------------------------
# Vim like copy / paste
#---------------------------------------------

# starts selection mode
bind C-[ copy-mode
bind -T copy-mode-vi 'v' send -X begin-selection

# Copy with 'y' or 'Enter'. No pipe command — set-clipboard on (above) makes
# tmux emit OSC 52 to the outer terminal, which then writes the system
# clipboard (alacritty → wl-clipboard on x1, Windows Terminal → Windows
# clipboard in WSL, alacritty on x1 → wl-clipboard over SSH to WSL tmux).
bind -T copy-mode-vi 'y'     send -X copy-pipe-and-cancel
bind -T copy-mode-vi 'Enter' send -X copy-pipe-and-cancel

# paste
bind p paste-buffer

# paste from system clipboard MacOS
# bind-key -n 'C-v' run \"tmux set-buffer \"$(reattach-to-user-namespace pbpaste)\"; tmux paste-buffer"

#---------------------------------------------
# Vim like navigation
#---------------------------------------------
is_vim="ps -o state= -o comm= -t '#{pane_tty}' \
    | grep -iqE '^[^TXZ ]+ +(\\S+\\/)?g?(view|l?n?vim?x?|fzf)(diff)?$'"

bind-key -n 'C-h' if-shell "$is_vim" 'send-keys C-h'  'select-pane -L'
bind-key -n 'C-j' if-shell "$is_vim" 'send-keys C-j'  'select-pane -D'
bind-key -n 'C-k' if-shell "$is_vim" 'send-keys C-k'  'select-pane -U'
bind-key -n 'C-l' if-shell "$is_vim" 'send-keys C-l'  'select-pane -R'

tmux_version='$(tmux -V | sed -En "s/^tmux ([0-9]+(.[0-9]+)?).*/\1/p")'
if-shell -b '[ "$(echo "$tmux_version < 3.0" | bc)" = 1 ]' \
    "bind-key -n 'C-\\' if-shell \"$is_vim\" 'send-keys C-\\'  'select-pane -l'"
if-shell -b '[ "$(echo "$tmux_version >= 3.0" | bc)" = 1 ]' \
    "bind-key -n 'C-\\' if-shell \"$is_vim\" 'send-keys C-\\\\'  'select-pane -l'"

bind-key -T copy-mode-vi 'C-h' select-pane -L
bind-key -T copy-mode-vi 'C-j' select-pane -D
bind-key -T copy-mode-vi 'C-k' select-pane -U
bind-key -T copy-mode-vi 'C-l' select-pane -R
bind-key -T copy-mode-vi 'C-\' select-pane -l

#---------------------------------------------
# Vim like pane resize
#---------------------------------------------
bind-key -n 'M-j' if-shell "$is_vim" 'send-keys M-j'  'resize-pane -D 3'
bind-key -n 'M-k' if-shell "$is_vim" 'send-keys M-k'  'resize-pane -U 3'
bind-key -n 'M-h' if-shell "$is_vim" 'send-keys M-h'  'resize-pane -L 3'
bind-key -n 'M-l' if-shell "$is_vim" 'send-keys M-l'  'resize-pane -R 3'

# Adapted from: https://github.com/ZachMassia/dotfiles/blob/master/tmux.conf

# Colors come from the palette mooncake component
# (components/palette/vars/{{ palette_variant }}.yml). The brightness
# ladder used here is sidebar < bg < panel < selection — UI chrome
# differentiates active state by brightness, not hue (Sublime ST2 way).
# The only hued accent in the chrome is orange on window activity.

# Denote window activity
set-window-option -g monitor-activity on
setw -g window-status-activity none

set -g status-style bg='{{ palette.sidebar }}',fg='{{ palette.muted }}'
set -g window-status-style bg='{{ palette.sidebar }}',fg='{{ palette.muted }}'
set -g window-status-current-style bg='{{ palette.panel }}',fg='{{ palette.fg }}',bold
set -g window-status-activity-style bg='{{ palette.sidebar }}',fg='{{ palette.orange }}'

# Sublime/Monokai-style active-pane emphasis: dim inactive pane contents so
# the active pane lights up. The bright green border seals the deal.
set -g window-style 'bg={{ palette.sidebar }}'
set -g window-active-style 'bg={{ palette.bg }}'
set -g pane-active-border-style bg='{{ palette.bg }}',fg='{{ palette.green }}'
set -g pane-border-style bg='{{ palette.sidebar }}',fg='{{ palette.selection }}'

# Extend the active-border color along the full length of every border
# touching the active pane (not just the segment directly adjacent).
set -g pane-border-indicators colour
set -g pane-border-lines heavy

# Title strip = synthetic top edge so the active pane reads as boxed in
# even against the terminal edge.
set -g pane-border-status top
set -g pane-border-format '#{?pane_active,#[bg={{ palette.green }}#,fg={{ palette.bg }}#,bold] #P  #{b:pane_current_path} ,#[bg={{ palette.sidebar }}#,fg={{ palette.muted }}] #P  #{b:pane_current_path} }'

set -g mode-style bg='{{ palette.selection }}',fg='{{ palette.fg }}'
set -g message-style bg='{{ palette.selection }}',fg='{{ palette.fg }}'
